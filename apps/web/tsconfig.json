{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noImplicitAny": false,
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@fit-check/shared/*": ["../shared/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "vite.config.ts",
    "index.html",
    "../shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "eslint.config.ts"
  ]
}
