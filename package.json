{
  "name": "fit-check-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "web:dev": "npm run dev -w apps/web",
    "web:build": "npm run build -w apps/web",
    "web:preview": "npm run preview -w apps/web",
    "web:lint": "npm run lint -w apps/web",
    "web:typecheck": "npm exec -w apps/web -- tsc -p tsconfig.json --noEmit",
    "api:dev": "npm run dev -w @fit-check/api",
    "api:build": "npm run build -w @fit-check/api",
    "api:start": "npm run start -w @fit-check/api",
    "api:lint": "npm run lint -w @fit-check/api",
    "api:test": "npm run test -w @fit-check/api",
    "database:build": "npm run build -w @fit-check/database",
    "database:generate": "npm run generate -w @fit-check/database",
    "database:migrate": "npm run migrate -w @fit-check/database",
    "database:push": "npm run push -w @fit-check/database"
  },
  "devDependencies": {
    "typescript-eslint": "^8.59.2"
  }
}
