{
  "name": "@fit-check/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "npm run typecheck && tsup --config tsup.config.ts",
    "start": "node dist/api/server.js",
    "lint": "NODE_OPTIONS='--experimental-strip-types' eslint --flag unstable_native_nodejs_ts_config .",
    "test": "node --import tsx --import ./test/helpers/register-pgmem.ts --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.918.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fit-check/database": "*",
    "@fit-check/shared": "*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "image-size": "^1.1.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.5",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-pgmem": "^0.6.2",
    "pg-mem": "^3.0.14",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2"
  },
  "imports": {
    "#lib/*": "./lib/*.js",
    "#routes/*": "./routes/*.js",
    "#types/*": "./types/*.js"
  }
}
