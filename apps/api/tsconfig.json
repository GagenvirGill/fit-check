{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@fit-check/shared/*": [
        "../shared/*"
      ],
      "@fit-check/database": [
        "../database"
      ],
      "@fit-check/database/*": [
        "../database/*"
      ],
      "#lib/*": [
        "./lib/*"
      ],
      "#routes/*": [
        "./routes/*"
      ],
      "#types/*": [
        "./types/*"
      ]
    }
  },
  "include": [
    "**/*",
    "../shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
