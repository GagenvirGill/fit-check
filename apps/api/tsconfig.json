{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@fit-check/shared/*": [
        "../shared/*"
      ],
      "@fit-check/database": [
        "../database"
      ],
      "@fit-check/database/*": [
        "../database/*"
      ],
      "#lib/*": [
        "./lib/*"
      ],
      "#routes/*": [
        "./routes/*"
      ],
      "#types/*": [
        "./types/*"
      ]
    }
  },
  "include": [
    "server.ts",
    "app.ts",
    "lib/**/*.ts",
    "routes/**/*.ts",
    "types/**/*.d.ts",
    "test/**/*.ts",
    "tsup.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
